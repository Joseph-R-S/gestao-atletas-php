{% extends "layout.html.twig" %}

{% block content %}
    <form  class="fomulario" method="POST" action="index.php?class=AtletaForm&method=save">
    {#{{ dump(atleta) }}#}
        <div class="input-container">
            <label for="id">ID:</label>
            <input type="number" id="id" name="id" readonly value="{{ atleta.id }}">
        </div>
        
        <div class="input-container">
            <label for="nome_completo">Nome:<span>*</span></label>
            <input type="text" id="nome_completo" name="nome_completo" placeholder="nome completo" 
                value="{{ atleta.nome_completo }}">
        </div>

        <div class="input-container">
            <label for="email">Email:<span>*</span></label>
            <input type="email" id="email" name="email" placeholder="exemplo@email.com" 
            value="{{ atleta.email }}">
        </div>

        <div class="input-container">
            <label for="sexo">Sexo:<span>*</span></label>
            <select name="sexo">
                <option value="M" {{ atleta.sexo == 'M' ? 'selected' : '' }}>Masculino</option>
                <option value="F" {{ atleta.sexo == 'F' ? 'selected' : '' }}>Feminino</option>
            </select>
        </div>

        <div class="input-container">
            <label for="telefone">telefone:<span>*</span></label>
            <input type="tel" id="telefone" name="telefone" placeholder="65123456789" 
            value="{{ atleta.telefone }}">
        </div>

        <div class="input-container">
            <label for="data_nascimento">data de nascimento:<span>*</span></label>
            <input type="date" id="data_nascimento" name="data_nascimento" 
            value="{{ atleta.data_nascimento }}">
        </div>
		<div class="form-footer">
			<div class="input-container">
				<button type="submit" class="btn-salvar-footer">SALVAR</button>
			</div>
		</div>
    </form>
    
{% endblock %}